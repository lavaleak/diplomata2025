{
    "compilerOptions": {
      "module": "nodenext",
      "target": "ES2020",
      "lib": [
        "ES2020",
        "dom",
        "dom.iterable",
        "ES2021.String"
      ],
      "removeComments": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "allowSyntheticDefaultImports": true,
      "sourceMap": true,
      "outDir": "./dist",
      "incremental": true,
      "moduleResolution": "nodenext",
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "typeRoots": [
        "./node_modules/@types",
        "src/types"
      ],
    },
    "include": [
      "src/**/*.ts",
      "src/**/*.mts",
    ],
    "exclude": [
      "node_modules",
      "scripts",
      "config"
    ]
  }